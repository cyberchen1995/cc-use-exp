# Optional proxy template for Codex in Mainland network environments.
# Usage:
# 1. Change the port to match your local proxy.
# 2. Copy this file to ~/.codex/.env for global reuse across projects,
#    or keep it as <project>/.codex/.env for project-only scope.
# 3. This file is not auto-synced by tools/sync-config.sh.
HTTP_PROXY="http://127.0.0.1:7897"
HTTPS_PROXY="http://127.0.0.1:7897"
NO_PROXY="localhost,127.0.0.1"
